# .streamlit/secrets.toml.example
#
# HOW TO USE
# ----------
# 1. Local development:
#    Copy this file to .streamlit/secrets.toml and fill in your key.
#    The real secrets.toml is git-ignored so it never gets committed.
#
# 2. Streamlit Community Cloud (deployed app):
#    Do NOT upload this file. Instead, go to your app's Settings →
#    Secrets and paste the key-value pairs directly into the UI.
#    Streamlit Cloud injects them as st.secrets at runtime.
#
# Get a free Groq API key at: https://console.groq.com/keys

GROQ_API_KEY = "your_groq_api_key_here"
